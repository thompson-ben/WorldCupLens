{
  "name": "worldcuplens",
  "version": "0.1.0",
  "private": true,
  "description": "WorldCupLens — a tournament-agnostic sports analytics platform.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @worldcuplens/web",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspace @worldcuplens/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  }
}
